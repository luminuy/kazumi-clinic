{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kazumi-clinic",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "kazumi-clinic"
    }
  ],
  // ISR background revalidation queue — required, without it OpenNext falls back to a
  // dummy queue that throws ("Dummy queue is not implemented") and stale pages never regenerate.
  "durable_objects": {
    "bindings": [
      {
        "name": "NEXT_CACHE_DO_QUEUE",
        "class_name": "DOQueueHandler"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["DOQueueHandler"]
    }
  ],
  // Run `wrangler r2 bucket create kazumi-clinic-cache` then update bucket_name below.
  "r2_buckets": [
    {
      "binding": "NEXT_INC_CACHE_R2_BUCKET",
      "bucket_name": "kazumi-clinic-cache"
    }
  ],
  // Run `wrangler d1 create kazumi-clinic-tag-cache` then update database_name/database_id below.
  "d1_databases": [
    {
      "binding": "NEXT_TAG_CACHE_D1",
      "database_name": "kazumi-clinic-tag-cache",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID"
    }
  ]
}
